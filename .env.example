# Server
PORT=5555

# MongoDB
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/your_db

# PayU Payment Gateway (same style as demo/mahabaleshwar-escapes)
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_SALT=your_merchant_salt
# TEST = sandbox (test.payu.in), LIVE or PRODUCTION = live (secure.payu.in)
PAYU_MODE=TEST

# API base for PayU surl/furl. Use origin only OR URL ending in /api — both work (no double /api).
# Examples: http://localhost:5555  OR  https://api.dometriks.com/api
API_BASE_URL=http://localhost:5555

# Frontend URL - where users are redirected after payment success/failure
# Examples: https://dometriks.com (production) or http://localhost:8080 (local)
FRONTEND_URL=http://localhost:8080

# Email (existing)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=office@dometriks.com
SMTP_PASS=your_smtp_password
