# Server
PORT=5555

# MongoDB
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/your_db

# PayUMoney Payment Gateway
# Get these from https://www.payumoney.com/ (Merchant Dashboard → Integration → Key Salt)
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_SALT=your_salt
# Use "test" for sandbox, "production" for live payments
PAYU_MODE=test

# Required for PayU callback URLs (surl/furl) - must be your backend's public URL
# Examples: https://api.dometriks.com (production) or http://localhost:5555 (local)
API_BASE_URL=http://localhost:5555

# Frontend URL - where users are redirected after payment success/failure
# Examples: https://dometriks.com (production) or http://localhost:8080 (local)
FRONTEND_URL=http://localhost:8080

# Email (existing)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=office@dometriks.com
SMTP_PASS=your_smtp_password
